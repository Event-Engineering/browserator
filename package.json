{
  "name": "tabosaurus",
  "version": "1.0.0",
  "description": "Multi-display fullscreen browser controller",
  "author": {
    "name": "Event Engineering",
    "email": "matt.james@event.engineering"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,yellow \"vite\" \"wait-on http://localhost:8080 && electron .\"",
    "start": "vite build && electron .",
    "package:mac": "vite build && electron-builder --mac --publish never",
    "package:win": "vite build && electron-builder --win --publish never",
    "build:icon": "node scripts/build-icon.js"
  },
  "build": {
    "appId": "com.tabosaurus.app",
    "productName": "Tabosaurus",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "identity": null,
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "vite": "^8.0.13",
    "wait-on": "^9.0.10"
  }
}
